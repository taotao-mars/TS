class CausalConv1d(nn.Module):
    def __init__(self, in_channels, out_channels, kernel_size=2, dilation=1):
        super().__init__()
        self.pad = (kernel_size - 1) * dilation
        self.conv = nn.Conv1d(
            in_channels,
            out_channels,
            kernel_size=kernel_size,
            dilation=dilation,
        )

    def forward(self, x):
        x = F.pad(x, (self.pad, 0))
        return self.conv(x)


class HistoryEncoder(nn.Module):
    def __init__(self, input_dim, d_model=64):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, d_model)

        dilations = [1, 2, 4, 8, 13, 26]
        self.convs = nn.ModuleList([
            CausalConv1d(d_model, d_model, kernel_size=2, dilation=d)
            for d in dilations
        ])
        self.norms = nn.ModuleList([nn.LayerNorm(d_model) for _ in dilations])
        self.final_norm = nn.LayerNorm(d_model)

    def forward(self, x):
        # x: [B,T,F]
        h = self.input_proj(x).transpose(1, 2)  # [B,D,T]

        for conv, norm in zip(self.convs, self.norms):
            z = conv(h)
            h = h + z
            h = h.transpose(1, 2)
            h = norm(h)
            h = F.gelu(h)
            h = h.transpose(1, 2)

        h = h.transpose(1, 2)  # [B,T,D]
        h_t = self.final_norm(h[:, -1, :])
        return h_t


class HorizonTCNBlock(nn.Module):
    def __init__(self, d_model, kernel_size=3, dilation=1, dropout=0.10):
        super().__init__()
        padding = dilation * (kernel_size - 1) // 2

        self.conv1 = nn.Conv1d(d_model, d_model, kernel_size, padding=padding, dilation=dilation)
        self.conv2 = nn.Conv1d(d_model, d_model, kernel_size, padding=padding, dilation=dilation)
        self.dropout = nn.Dropout(dropout)
        self.norm = nn.LayerNorm(d_model)

    def forward(self, x):
        # x: [B,H,D]
        res = x
        z = x.transpose(1, 2)
        z = F.relu(self.conv1(z))
        z = self.dropout(z)
        z = F.relu(self.conv2(z))
        z = self.dropout(z)
        z = z.transpose(1, 2)

        if z.shape[1] != res.shape[1]:
            m = min(z.shape[1], res.shape[1])
            z = z[:, :m, :]
            res = res[:, :m, :]

        return self.norm(res + z)


class ExposureTCNDecoder(nn.Module):
    """
    Direct exposure decoder with:
      1. auxiliary exposure occurrence head
      2. auxiliary demand occurrence head
      3. horizon block-specific heads

    Main output:
      level_head directly predicts log1p(total/buy_box/in_stock DPH).

    Auxiliary outputs:
      exposure_occ_head predicts P(DPH > 0)
      demand_occ_head predicts P(demand > 0)

    Horizon blocks:
      short: h=1-5
      mid:   h=6-12
      long:  h=13-20

    Future true demand is used only as auxiliary label during training.
    It is never used as model input.
    """
    def __init__(self, d_model, context_dim, horizon=20, hidden=96, dropout=0.10):
        super().__init__()
        self.horizon = horizon
        self.hidden = hidden

        self.input_proj = nn.Sequential(
            nn.Linear(d_model + context_dim + 2, hidden),
            nn.ReLU(),
            nn.Dropout(dropout),
        )

        self.tcn = nn.ModuleList([
            HorizonTCNBlock(hidden, dilation=1, dropout=dropout),
            HorizonTCNBlock(hidden, dilation=2, dropout=dropout),
            HorizonTCNBlock(hidden, dilation=4, dropout=dropout),
        ])

        self.shared = nn.Sequential(
            nn.Linear(hidden, hidden),
            nn.ReLU(),
            nn.Dropout(dropout * 0.5),
        )

        # Block-specific direct level heads.
        self.level_head_short = nn.Linear(hidden, 3)
        self.level_head_mid = nn.Linear(hidden, 3)
        self.level_head_long = nn.Linear(hidden, 3)

        # Block-specific auxiliary exposure occurrence heads.
        self.exp_occ_head_short = nn.Linear(hidden, 3)
        self.exp_occ_head_mid = nn.Linear(hidden, 3)
        self.exp_occ_head_long = nn.Linear(hidden, 3)

        # Block-specific auxiliary demand occurrence heads.
        # Single output per horizon: P(future_demand > 0)
        self.dem_occ_head_short = nn.Linear(hidden, 1)
        self.dem_occ_head_mid = nn.Linear(hidden, 1)
        self.dem_occ_head_long = nn.Linear(hidden, 1)

    def _block_masks(self, H, device):
        """
        short: h=1-5
        mid:   h=6-12
        long:  h=13-20
        """
        idx = torch.arange(H, device=device)
        short = idx <= 4
        mid = (idx >= 5) & (idx <= 11)
        long = idx >= 12
        return short, mid, long

    def forward(self, h_t, future_context, return_components=False):
        B, H, C = future_context.shape

        h_rep = h_t.unsqueeze(1).expand(B, H, h_t.shape[-1])

        horizon_idx = torch.arange(H, device=future_context.device).float()
        horizon_idx = horizon_idx.view(1, H, 1).expand(B, H, 1) / max(H, 1)

        hsin = torch.sin(2 * np.pi * horizon_idx)
        hcos = torch.cos(2 * np.pi * horizon_idx)

        x = torch.cat([h_rep, future_context, hsin, hcos], dim=-1)

        z = self.input_proj(x)

        for block in self.tcn:
            z = block(z)

        z = self.shared(z)

        # Compute all block heads.
        level_short = self.level_head_short(z)
        level_mid = self.level_head_mid(z)
        level_long = self.level_head_long(z)

        exp_occ_short = self.exp_occ_head_short(z)
        exp_occ_mid = self.exp_occ_head_mid(z)
        exp_occ_long = self.exp_occ_head_long(z)

        dem_occ_short = self.dem_occ_head_short(z)
        dem_occ_mid = self.dem_occ_head_mid(z)
        dem_occ_long = self.dem_occ_head_long(z)

        short_mask, mid_mask, long_mask = self._block_masks(H, z.device)

        level_raw = torch.zeros(B, H, 3, device=z.device, dtype=z.dtype)
        exp_occ_logit = torch.zeros(B, H, 3, device=z.device, dtype=z.dtype)
        dem_occ_logit = torch.zeros(B, H, 1, device=z.device, dtype=z.dtype)

        level_raw[:, short_mask, :] = level_short[:, short_mask, :]
        level_raw[:, mid_mask, :] = level_mid[:, mid_mask, :]
        level_raw[:, long_mask, :] = level_long[:, long_mask, :]

        exp_occ_logit[:, short_mask, :] = exp_occ_short[:, short_mask, :]
        exp_occ_logit[:, mid_mask, :] = exp_occ_mid[:, mid_mask, :]
        exp_occ_logit[:, long_mask, :] = exp_occ_long[:, long_mask, :]

        dem_occ_logit[:, short_mask, :] = dem_occ_short[:, short_mask, :]
        dem_occ_logit[:, mid_mask, :] = dem_occ_mid[:, mid_mask, :]
        dem_occ_logit[:, long_mask, :] = dem_occ_long[:, long_mask, :]

        # Direct final exposure prediction.
        level_log_hat = F.softplus(level_raw)
        pred_level = torch.expm1(level_log_hat).clamp(min=0.0)

        prob_exp_active = torch.sigmoid(exp_occ_logit)
        prob_demand_active = torch.sigmoid(dem_occ_logit).squeeze(-1)

        if return_components:
            return {
                "pred_level": pred_level,
                "level_log_hat": level_log_hat,
                "exp_occ_logit": exp_occ_logit,
                "prob_exp_active": prob_exp_active,
                "dem_occ_logit": dem_occ_logit.squeeze(-1),
                "prob_demand_active": prob_demand_active,
            }

        return level_log_hat


class ExposureForecastModel(nn.Module):
    def __init__(self, input_dim, context_dim, d_model=64, horizon=20):
        super().__init__()
        self.encoder = HistoryEncoder(input_dim=input_dim, d_model=d_model)
        self.decoder = ExposureTCNDecoder(
            d_model=d_model,
            context_dim=context_dim,
            horizon=horizon,
            hidden=max(96, d_model * 2),
        )

    def forward(self, x, future_context, return_components=False):
        h_t = self.encoder(x)
        return self.decoder(h_t, future_context, return_components=return_components)


# ============================================================
# 5. Loss / training
# ============================================================

def exposure_loss(
    model_out,
    true_total,
    true_buy,
    true_instock,
    true_demand=None,
    w_total=0.30,
    w_buy=0.60,
    w_instock=1.00,
    mean_weight=0.20,
    exp_occ_weight=0.30,
    demand_occ_weight=0.08,
    block_calib_weight=0.10,
):
    """
    Direct level loss + auxiliary exposure occurrence + auxiliary demand occurrence.

    Important:
      Future true demand is used only as an auxiliary label.
      It is not used as input.

    Main prediction remains direct level:
      pred_total_dph
      pred_buy_box_dph
      pred_instock_dph
    """
    true = torch.stack(
        [
            true_total.clamp(min=0),
            true_buy.clamp(min=0),
            true_instock.clamp(min=0),
        ],
        dim=-1,
    )

    target_log = torch.log1p(true)
    exp_active = (true > 0).float()

    pred_level = model_out["pred_level"]
    level_log_hat = model_out["level_log_hat"]
    exp_occ_logit = model_out["exp_occ_logit"]

    weights = torch.tensor(
        [w_total, w_buy, w_instock],
        dtype=level_log_hat.dtype,
        device=level_log_hat.device,
    ).view(1, 1, 3)

    # Main direct level loss.
    level_err = F.huber_loss(
        level_log_hat,
        target_log,
        delta=1.0,
        reduction="none",
    )
    level_loss = (level_err * weights).mean()

    # Auxiliary exposure occurrence loss.
    exp_occ_err = F.binary_cross_entropy_with_logits(
        exp_occ_logit,
        exp_active,
        reduction="none",
    )
    exp_occ_loss = (exp_occ_err * weights).mean()

    # Auxiliary demand occurrence loss.
    dem_occ_loss = torch.tensor(0.0, device=level_log_hat.device)
    if true_demand is not None and "dem_occ_logit" in model_out:
        dem_active = (true_demand.clamp(min=0) > 0).float()
        dem_occ_loss = F.binary_cross_entropy_with_logits(
            model_out["dem_occ_logit"],
            dem_active,
            reduction="mean",
        )

    # Overall mean calibration.
    mean_pred = torch.log1p(pred_level.mean(dim=(0, 1)))
    mean_true = torch.log1p(true.mean(dim=(0, 1)))
    mean_loss = torch.mean(torch.abs(mean_pred - mean_true) * weights.view(3))

    # Block-wise calibration.
    B, H, _ = true.shape
    idx = torch.arange(H, device=true.device)
    masks = [
        idx <= 4,
        (idx >= 5) & (idx <= 11),
        idx >= 12,
    ]

    block_losses = []
    for m in masks:
        if m.sum() == 0:
            continue
        pred_m = torch.log1p(pred_level[:, m, :].mean(dim=(0, 1)))
        true_m = torch.log1p(true[:, m, :].mean(dim=(0, 1)))
        block_losses.append(torch.mean(torch.abs(pred_m - true_m) * weights.view(3)))

    if len(block_losses) > 0:
        block_calib_loss = torch.stack(block_losses).mean()
    else:
        block_calib_loss = torch.tensor(0.0, device=true.device)

    return (
        level_loss
        + exp_occ_weight * exp_occ_loss
        + demand_occ_weight * dem_occ_loss
        + mean_weight * mean_loss
        + block_calib_weight * block_calib_loss
    )

def train_exposure_model(
    model,
    tr_ld,
    va_ld,
    epochs=60,
    lr=1e-3,
    patience=8,
    w_total=0.30,
    w_buy=0.60,
    w_instock=1.00,
    mean_weight=0.20,
):
    opt = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=1e-5)
    sch = torch.optim.lr_scheduler.CosineAnnealingLR(opt, T_max=max(epochs, 1))

    best_val = float("inf")
    best_sd = None
    no_improve = 0

    for epoch in range(epochs):
        model.train()
        tr_sum, tr_n = 0.0, 0

        for b in tr_ld:
            model_out = model(b["x"], b["future_context"], return_components=True)

            loss = exposure_loss(
                model_out,
                b["future_total_dph"],
                b["future_buy_box_dph"],
                b["future_instock_dph"],
                true_demand=b.get("future_demand", None),
                w_total=w_total,
                w_buy=w_buy,
                w_instock=w_instock,
                mean_weight=mean_weight,
            )

            opt.zero_grad()
            loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            opt.step()

            tr_sum += loss.item() * b["x"].shape[0]
            tr_n += b["x"].shape[0]

        sch.step()

        model.eval()
        va_sum, va_n = 0.0, 0

        with torch.no_grad():
            for b in va_ld:
                model_out = model(b["x"], b["future_context"], return_components=True)
                loss = exposure_loss(
                    model_out,
                    b["future_total_dph"],
                    b["future_buy_box_dph"],
                    b["future_instock_dph"],
                    w_total=w_total,
                    w_buy=w_buy,
                    w_instock=w_instock,
                    mean_weight=mean_weight,
                )
                va_sum += loss.item() * b["x"].shape[0]
                va_n += b["x"].shape[0]

        tr_loss = tr_sum / max(tr_n, 1)
        va_loss = va_sum / max(va_n, 1)

        print(f"Epoch {epoch+1:03d} | train={tr_loss:.5f} | val={va_loss:.5f}")

        if va_loss < best_val - 1e-6:
            best_val = va_loss
            best_sd = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}
            no_improve = 0
        else:
            no_improve += 1

        if no_improve >= patience:
            print(f"Early stop at epoch {epoch+1}. Best val={best_val:.5f}")
            break

    if best_sd is not None:
        model.load_state_dict(best_sd)

    return model



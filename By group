# 11. Regime-wise Evaluation by ASIN Zero Rate
# =====================================================

def evaluate_wape_by_zero_rate_group(
    forecast_df,
    pred_cols=("p50_amxl", "p70_amxl"),
    y_col="fbi_demand",
    asin_col="asin",
    zero_thresholds=(0.4, 0.7),
):
    """
    Evaluate WAPE / underbias / overbias by ASIN-level zero-rate groups.

    Group definition:
      low_sparse  : zero_rate < 0.4
      mid_sparse  : 0.4 <= zero_rate < 0.7
      high_sparse : zero_rate >= 0.7

    zero_rate is computed within the validation forecast window.
    """
    df = forecast_df.copy()

    asin_stats = (
        df.groupby(asin_col)
        .agg(
            zero_rate=(y_col, lambda x: (x == 0).mean()),
            total_demand=(y_col, "sum"),
            n_weeks=(y_col, "count"),
        )
        .reset_index()
    )

    low, high = zero_thresholds

    def assign_group(z):
        if z < low:
            return "low_sparse"
        elif z < high:
            return "mid_sparse"
        else:
            return "high_sparse"

    asin_stats["zero_group"] = asin_stats["zero_rate"].apply(assign_group)

    df = df.merge(
        asin_stats[[asin_col, "zero_rate", "zero_group"]],
        on=asin_col,
        how="left",
    )

    rows = []

    for group, g in df.groupby("zero_group"):
        y = g[y_col].values.astype(float)
        denom = max(np.abs(y).sum(), 1e-8)

        row = {
            "zero_group": group,
            "n_asins": g[asin_col].nunique(),
            "n_rows": len(g),
            "avg_zero_rate": g["zero_rate"].mean(),
            "median_zero_rate": g["zero_rate"].median(),
            "total_demand": y.sum(),
            "true_active_ratio": (y > 0).mean(),
        }

        for pred_col in pred_cols:
            pred = g[pred_col].values.astype(float)

            under = np.maximum(y - pred, 0).sum() / denom
            over = np.maximum(pred - y, 0).sum() / denom
            wape = np.abs(y - pred).sum() / denom
            pred_active_ratio = (pred > 0).mean()

            row[f"{pred_col}_wape"] = wape
            row[f"{pred_col}_underbias"] = under
            row[f"{pred_col}_overbias"] = over
            row[f"{pred_col}_pred_active_ratio"] = pred_active_ratio

        rows.append(row)

    result = pd.DataFrame(rows)

    order = ["low_sparse", "mid_sparse", "high_sparse"]
    result["zero_group"] = pd.Categorical(
        result["zero_group"],
        categories=order,
        ordered=True,
    )
    result = result.sort_values("zero_group").reset_index(drop=True)

    asin_counts = (
        asin_stats.groupby("zero_group")[asin_col]
        .nunique()
        .reset_index(name="n_asins")
    )
    asin_counts["zero_group"] = pd.Categorical(
        asin_counts["zero_group"],
        categories=order,
        ordered=True,
    )
    asin_counts = asin_counts.sort_values("zero_group").reset_index(drop=True)

    return result, asin_stats, df, asin_counts



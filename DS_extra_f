    if candidate in data_raw1.columns:
        group_col_to_use = candidate
        break

eda_result = run_dph_demand_eda_print_only(
    data_raw1,
    demand_col="fbi_demand",
    dph_cols=("total_dph", "buy_box_dph", "in_stock_dph"),
    date_col="order_week",
    group_col=group_col_to_use,
)
